{
  "name": "north",
  "productName": "North Finances",
  "version": "1.5.0",
  "description": "Controle financeiro pessoal — 100% local",
  "main": "electron/main.js",
  "author": "Pedro Barssottini Gianchetta",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.northfinances.app",
    "productName": "North Finances",
    "files": [
      "electron/**/*",
      "logo.ico"
    ],
    "win": {
      "icon": "logo.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "logo.ico",
      "uninstallerIcon": "logo.ico",
      "installerHeaderIcon": "logo.ico",
      "installerSidebar": "build/installerSidebar.bmp",
      "uninstallerSidebar": "build/installerSidebar.bmp",
      "installerHeader": "build/installerHeader.bmp",
      "artifactName": "North-Setup-${version}.${ext}",
      "shortcutName": "North Finances",
      "uninstallDisplayName": "North Finances"
    }
  }
}
